{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "MultiEdit",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(**/.claude/**)",
      "Write(**/.claude/**)",
      "Edit(**/.claude)",
      "Write(**/.claude)",
      "Edit(/Users/patrik.lindeberg/Claude Code/Axcion AI Repo/**)",
      "Write(/Users/patrik.lindeberg/Claude Code/Axcion AI Repo/**)",
      "Edit(logs/**)",
      "Write(logs/**)",
      "Edit(audits/**)",
      "Write(audits/**)",
      "Edit(skills/**)",
      "Write(skills/**)",
      "Edit(workflows/**)",
      "Write(workflows/**)",
      "Edit(prompts/**)",
      "Write(prompts/**)",
      "Edit(docs/**)",
      "Write(docs/**)",
      "Edit(scripts/**)",
      "Write(scripts/**)",
      "Edit(reports/**)",
      "Write(reports/**)",
      "Edit(inbox/**)",
      "Write(inbox/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Bash(git add *)",
      "Bash(git add:*)",
      "Bash(git commit *)",
      "Bash(git commit:*)",
      "Bash(git restore *)",
      "Bash(git restore:*)",
      "Bash(chmod *)",
      "Bash(chmod:*)",
      "Bash(mkdir *)",
      "Bash(mkdir:*)",
      "Bash(cp *)",
      "Bash(cp:*)"
    ],
    "deny": [
      "Read(archive/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/check-heavy-tool.sh",
            "timeout": 5,
            "statusMessage": "Heavy-tool check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/check-stop-reminders.sh",
            "timeout": 5,
            "statusMessage": "Checking session-end reminders..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/friday-checkup-reminder.sh",
            "timeout": 5,
            "statusMessage": "Checking Friday cadence..."
          }
        ]
      }
    ]
  }
}
