{
  "permissions": {
    "allow": [
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(logs/**)",
      "Write(logs/**)",
      "Edit(audits/**)",
      "Write(audits/**)",
      "Edit(skills/**)",
      "Write(skills/**)",
      "Edit(workflows/**)",
      "Write(workflows/**)",
      "Edit(prompts/**)",
      "Write(prompts/**)",
      "Edit(docs/**)",
      "Write(docs/**)",
      "Edit(scripts/**)",
      "Write(scripts/**)",
      "Edit(reports/**)",
      "Write(reports/**)",
      "Edit(inbox/**)",
      "Write(inbox/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Bash(git add *)",
      "Bash(git add:*)",
      "Bash(git commit *)",
      "Bash(git commit:*)",
      "Bash(git restore *)",
      "Bash(git restore:*)",
      "Bash(chmod *)",
      "Bash(chmod:*)",
      "Bash(mkdir *)",
      "Bash(mkdir:*)",
      "Bash(cp *)",
      "Bash(cp:*)"
    ],
    "deny": [
      "Read(archive/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\"; REGISTRY=\"$PROJECT_DIR/logs/innovation-registry.md\"; detected=0; [ -f \"$REGISTRY\" ] && detected=$(grep -c '| detected |' \"$REGISTRY\" 2>/dev/null || echo 0); if [ \"$detected\" -gt 0 ]; then echo \"{\\\"systemMessage\\\":\\\"$detected innovation(s) pending triage. Run /wrap-session before ending to log this session and triage innovations.\\\"}\"; else echo '{\"systemMessage\":\"Consider running /wrap-session before ending to log this session.\"}'; fi",
            "timeout": 5,
            "statusMessage": "Checking for /wrap-session..."
          }
        ]
      }
    ]
  }
}
