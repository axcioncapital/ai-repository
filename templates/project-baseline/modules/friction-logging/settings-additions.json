{
  "_comment": "Merge these entries into the project's settings.json hooks object",
  "PreToolUse": [
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/friction-log-auto.sh\"",
          "timeout": 5,
          "statusMessage": "Checking friction log..."
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/log-write-activity.sh\"",
          "timeout": 5,
          "statusMessage": "Logging write activity..."
        }
      ]
    },
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/log-write-activity.sh\"",
          "timeout": 5,
          "statusMessage": "Logging write activity..."
        }
      ]
    }
  ]
}
